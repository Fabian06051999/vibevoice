{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Voice Tool",
  "version": "0.1.0",
  "identifier": "com.kowal.vibe-voice-tool",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vibe Voice Tool",
        "width": 440,
        "height": 570,
        "visible": false,
        "center": true,
        "resizable": false,
        "url": "index.html"
      },
      {
        "label": "overlay",
        "title": "Recording",
        "url": "overlay.html",
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "width": 220,
        "height": 44,
        "resizable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
