{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Voice Tool",
  "version": "0.1.0",
  "identifier": "com.kowal.vibe-voice-tool",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vibe Voice Tool",
        "width": 440,
        "height": 570,
        "visible": false,
        "center": true,
        "resizable": false,
        "url": "index.html"
      },
      {
        "label": "overlay",
        "title": "Recording",
        "url": "overlay.html",
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "width": 220,
        "height": 44,
        "resizable": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "category": "Productivity",
    "copyright": "Copyright © 2026 Fabian Kowalewski",
    "homepage": "https://github.com/Fabian06051999/vibevoice",
    "shortDescription": "Voice-to-text for AI coding prompts",
    "longDescription": "Vibe Voice is a push-to-talk voice-to-text tool built for vibe coding. Hold Ctrl+Win, speak your instruction, and paste it at your cursor.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "upgradeCode": "ee26d992-14c4-5b52-81bf-1b663ee1c685",
        "language": ["en-US", "de-DE"]
      }
    }
  }
}
